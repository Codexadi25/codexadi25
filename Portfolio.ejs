<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Aditya Sahu | Developer Portfolio</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@300;400;500;600&family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,400&display=swap" rel="stylesheet"/>
<script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
<style>
/* ═══════════════════════ RESET & TOKENS ═══════════════════════ */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#08080f;
  --bg2:#0d0d18;
  --bg3:#111120;
  --card:#151525;
  --card2:#1a1a2e;
  --border:#1f1f38;
  --border2:#2a2a48;
  --accent:#6c63ff;
  --accent2:#ff6584;
  --accent3:#43e97b;
  --accent-dim:rgba(108,99,255,.12);
  --accent-glow:rgba(108,99,255,.3);
  --cyan:#00d4ff;
  --amber:#ffd166;
  --text:#f0eeff;
  --text2:#8888bb;
  --text3:#44446a;
  --mono:'Fira Code',monospace;
  --display:'Syne',sans-serif;
  --sans:'DM Sans',sans-serif;
  --sidebar:270px;
  --radius:12px;
  --grad:linear-gradient(135deg,#6c63ff,#ff6584);
}
html{scroll-behavior:smooth;font-size:15px}
body{font-family:var(--sans);background:var(--bg);color:var(--text);overflow-x:hidden;min-height:100vh}
a{text-decoration:none;color:inherit}
img{max-width:100%;display:block}
button,input,textarea,select{cursor:pointer;font-family:inherit}
input,textarea{cursor:text}
::-webkit-scrollbar{width:4px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:4px}
::-webkit-scrollbar-thumb:hover{background:var(--accent)}

/* ═══════════════════════ NOISE TEXTURE OVERLAY ═══════════════════════ */
body::before{
  content:'';position:fixed;inset:0;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
  pointer-events:none;z-index:9999;opacity:.4;
}

/* ═══════════════════════ LAYOUT ═══════════════════════ */
#layout{display:flex;min-height:100vh}

/* ═══════════════════════ SIDEBAR ═══════════════════════ */
#sidebar{
  width:var(--sidebar);min-height:100vh;
  background:var(--bg2);
  border-right:1px solid var(--border);
  position:fixed;top:0;left:0;
  display:flex;flex-direction:column;
  padding:2rem 1.5rem;
  z-index:100;overflow-y:auto;
}
.avatar-wrap{
  position:relative;width:80px;height:80px;
  margin:0 auto 1rem;
}
.avatar-ring{
  position:absolute;inset:-3px;
  border-radius:50%;
  background:var(--grad);
  animation:spin 8s linear infinite;
}
@keyframes spin{to{transform:rotate(360deg)}}
.avatar-ring-inner{
  position:absolute;inset:2px;
  border-radius:50%;
  background:var(--bg2);
}
.avatar-wrap img,.avatar-placeholder{
  position:relative;z-index:2;
  width:80px;height:80px;border-radius:50%;
  object-fit:cover;
}
.avatar-placeholder{
  background:linear-gradient(135deg,var(--accent),#3b2fa8);
  display:flex;align-items:center;justify-content:center;
  font-family:var(--mono);font-size:1.8rem;font-weight:600;
  color:#fff;
}
.status-dot{
  position:absolute;bottom:3px;right:3px;z-index:3;
  width:13px;height:13px;
  background:var(--accent3);border-radius:50%;
  border:2px solid var(--bg2);
}
.status-dot::after{
  content:'';position:absolute;inset:-3px;
  border-radius:50%;
  background:rgba(67,233,123,.3);
  animation:pulse 2s infinite;
}
@keyframes pulse{0%,100%{transform:scale(1);opacity:.7}50%{transform:scale(1.8);opacity:0}}

.sidebar-name{
  font-family:var(--display);font-weight:800;font-size:1rem;
  text-align:center;letter-spacing:-.02em;
}
.sidebar-role{
  font-family:var(--mono);font-size:.6rem;
  text-align:center;color:var(--accent);
  margin-top:.3rem;letter-spacing:.1em;
}
.sidebar-divider{height:1px;background:var(--border);margin:1.2rem 0}

.nav-section-label{
  font-size:.55rem;letter-spacing:.18em;text-transform:uppercase;
  color:var(--text3);margin-bottom:.4rem;font-family:var(--mono);
}
nav ul{list-style:none;display:flex;flex-direction:column;gap:.15rem}
nav ul a{
  display:flex;align-items:center;gap:.6rem;
  padding:.5rem .75rem;border-radius:8px;
  font-size:.8rem;font-weight:500;color:var(--text2);
  transition:all .2s;position:relative;overflow:hidden;
}
nav ul a::before{
  content:'';position:absolute;left:0;top:0;bottom:0;
  width:0;background:var(--accent-dim);
  transition:width .2s;border-radius:8px;
}
nav ul a:hover{color:var(--text)}
nav ul a:hover::before{width:100%}
nav ul a.active{color:var(--accent)}
nav ul a.active::after{
  content:'';position:absolute;left:0;top:50%;transform:translateY(-50%);
  width:3px;height:55%;background:var(--accent);border-radius:2px;
}
.nav-ico{font-size:.85rem;width:16px;text-align:center;position:relative;z-index:1}
nav ul a span:last-child{position:relative;z-index:1}

.gh-mini{
  display:grid;grid-template-columns:1fr 1fr;gap:.4rem;
  margin-top:1.2rem;
}
.gh-mini-card{
  background:var(--bg3);border:1px solid var(--border);
  border-radius:8px;padding:.45rem;text-align:center;
  transition:border-color .2s;
}
.gh-mini-card:hover{border-color:var(--accent)}
.gh-mini-val{font-family:var(--mono);font-size:.9rem;font-weight:600;color:var(--accent)}
.gh-mini-lbl{font-size:.5rem;color:var(--text3);text-transform:uppercase;letter-spacing:.08em;margin-top:2px}

.social-row{
  display:flex;gap:.4rem;justify-content:center;
  margin-top:auto;padding-top:1.2rem;flex-wrap:wrap;
}
.soc-btn{
  width:30px;height:30px;border:1px solid var(--border);
  border-radius:7px;display:flex;align-items:center;justify-content:center;
  color:var(--text3);transition:all .2s;
}
.soc-btn:hover{border-color:var(--accent);color:var(--accent);background:var(--accent-dim)}
.soc-btn svg{width:13px;height:13px}

/* Resume DL pill */
.resume-dl{
  margin-top:.75rem;
  display:flex;align-items:center;justify-content:center;gap:.4rem;
  font-family:var(--mono);font-size:.6rem;letter-spacing:.06em;
  color:var(--text3);border:1px solid var(--border);
  border-radius:7px;padding:.45rem .8rem;
  transition:all .2s;cursor:pointer;background:transparent;width:100%;
}
.resume-dl:hover{border-color:var(--accent3);color:var(--accent3);background:rgba(67,233,123,.07)}
.resume-dl svg{width:12px;height:12px;flex-shrink:0}

/* Admin Button */
.admin-btn{
  margin-top:.5rem;
  display:flex;align-items:center;justify-content:center;gap:.4rem;
  font-family:var(--mono);font-size:.58rem;letter-spacing:.06em;
  color:var(--text3);border:1px solid var(--border);
  border-radius:7px;padding:.4rem .8rem;
  transition:all .2s;cursor:pointer;background:transparent;width:100%;
}
.admin-btn:hover{border-color:var(--accent2);color:var(--accent2);background:rgba(255,101,132,.07)}
.admin-btn svg{width:11px;height:11px}

/* ═══════════════════════ MAIN ═══════════════════════ */
#main{margin-left:var(--sidebar);flex:1;min-height:100vh}

/* ═══════════════════════ HERO ═══════════════════════ */
#hero{
  position:relative;overflow:hidden;
  min-height:100vh;
  display:flex;flex-direction:column;justify-content:center;
  padding:5rem 4.5rem 4rem;
  border-bottom:1px solid var(--border);
}
.hero-mesh{
  position:absolute;inset:0;pointer-events:none;
  background:
    radial-gradient(ellipse 600px 400px at 80% 20%,rgba(108,99,255,.1) 0%,transparent 70%),
    radial-gradient(ellipse 400px 300px at 20% 80%,rgba(67,233,123,.06) 0%,transparent 70%),
    radial-gradient(ellipse 300px 300px at 60% 70%,rgba(255,101,132,.05) 0%,transparent 70%);
}
.hero-grid{
  position:absolute;inset:0;
  background-image:
    linear-gradient(rgba(108,99,255,.05) 1px,transparent 1px),
    linear-gradient(90deg,rgba(108,99,255,.05) 1px,transparent 1px);
  background-size:60px 60px;
  pointer-events:none;
}
.hero-badge{
  display:inline-flex;align-items:center;gap:.5rem;
  font-family:var(--mono);font-size:.65rem;color:var(--accent3);
  letter-spacing:.1em;margin-bottom:1.75rem;
  border:1px solid rgba(67,233,123,.25);
  border-radius:100px;padding:.3rem .85rem;
  background:rgba(67,233,123,.05);
  width:fit-content;
}
.hero-badge::before{
  content:'';width:6px;height:6px;border-radius:50%;
  background:var(--accent3);
  box-shadow:0 0 8px var(--accent3);
  animation:pulse 1.5s infinite;
}
h1.hero-title{
  font-family:var(--display);font-weight:800;
  font-size:clamp(3rem,7vw,6.5rem);
  line-height:.9;letter-spacing:-.04em;
  color:var(--text);margin-bottom:.75rem;
}
h1.hero-title .line2{
  background:var(--grad);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  background-clip:text;
}
.hero-sub{
  font-family:var(--mono);font-size:clamp(.75rem,1.2vw,.9rem);
  color:var(--text3);margin-bottom:2rem;letter-spacing:.04em;
}
.hero-sub .hl{color:var(--cyan)}
.hero-desc{
  font-size:.9rem;color:var(--text2);
  max-width:540px;line-height:1.9;margin-bottom:2.5rem;
}
.hero-tags{display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:2.5rem}
.htag{
  font-family:var(--mono);font-size:.62rem;
  background:var(--card);border:1px solid var(--border);
  border-radius:6px;padding:.28rem .65rem;
  color:var(--text2);transition:all .2s;
}
.htag:hover{border-color:var(--accent);color:var(--accent)}
.hero-ctas{display:flex;gap:.8rem;flex-wrap:wrap}

.btn{
  display:inline-flex;align-items:center;gap:.5rem;
  padding:.72rem 1.5rem;border-radius:9px;
  font-size:.78rem;font-weight:600;
  letter-spacing:.05em;text-transform:uppercase;
  border:none;cursor:pointer;
  transition:all .2s;font-family:var(--sans);
}
.btn:hover{transform:translateY(-2px)}
.btn-primary{
  background:var(--grad);color:#fff;
  box-shadow:0 4px 24px var(--accent-glow);
}
.btn-primary:hover{box-shadow:0 8px 36px var(--accent-glow)}
.btn-ghost{
  background:transparent;color:var(--text);
  border:1px solid var(--border2);
}
.btn-ghost:hover{border-color:var(--accent);color:var(--accent)}
.btn-green{background:var(--accent3);color:#0a1a0f;box-shadow:0 4px 18px rgba(67,233,123,.3)}
.btn-green:hover{box-shadow:0 8px 28px rgba(67,233,123,.45)}
.btn svg{width:14px;height:14px;flex-shrink:0}

/* ═══════════════════════ SECTIONS ═══════════════════════ */
.section{padding:5rem 4.5rem;border-bottom:1px solid var(--border)}
.section:last-child{border-bottom:none}
.sec-eyebrow{
  font-family:var(--mono);font-size:.6rem;
  color:var(--accent);letter-spacing:.2em;text-transform:uppercase;
  display:flex;align-items:center;gap:.5rem;margin-bottom:.5rem;
}
.sec-eyebrow::before{content:'//';opacity:.4}
h2.sec-title{
  font-family:var(--display);font-weight:800;
  font-size:clamp(1.8rem,3.5vw,3rem);
  letter-spacing:-.04em;color:var(--text);
  margin-bottom:2.5rem;
}

/* ═══════════════════════ ABOUT ═══════════════════════ */
#about{background:var(--bg2)}
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:3.5rem;align-items:start}

.code-block{
  background:var(--bg3);border:1px solid var(--border);
  border-radius:var(--radius);overflow:hidden;
  box-shadow:0 20px 60px rgba(0,0,0,.4);
}
.code-block-header{
  display:flex;align-items:center;gap:.5rem;
  padding:.6rem 1rem;
  background:var(--card);border-bottom:1px solid var(--border);
}
.code-dot{width:10px;height:10px;border-radius:50%}
.code-dot.r{background:#ff5f57}.code-dot.a{background:#febc2e}.code-dot.g{background:#28c840}
.code-filename{font-family:var(--mono);font-size:.62rem;color:var(--text3);margin-left:.5rem}
.code-body{padding:1.2rem 1.5rem;font-family:var(--mono);font-size:.73rem;line-height:2;color:var(--text2)}
.c-kw{color:#c792ea}.c-fn{color:#82aaff}.c-str{color:#c3e88d}
.c-num{color:var(--amber)}.c-cmt{color:var(--text3);font-style:italic}
.c-cls{color:#ffcb6b}.c-prop{color:#f07178}
.c-line{display:block}.c-i{display:inline-block;width:1.5em}
.c-i2{display:inline-block;width:3em}.c-i3{display:inline-block;width:4.5em}

.about-prose p{font-size:.875rem;color:var(--text2);line-height:1.95;margin-bottom:1rem}
.about-prose p strong{color:var(--text);font-weight:600}

.skills-section{margin-top:1.75rem}
.skills-section h4{
  font-family:var(--mono);font-size:.6rem;text-transform:uppercase;
  letter-spacing:.15em;color:var(--text3);margin-bottom:.75rem;
}
.chips{display:flex;flex-wrap:wrap;gap:.4rem}
.chip{
  font-family:var(--mono);font-size:.63rem;
  background:var(--card);border:1px solid var(--border);
  border-radius:6px;padding:.26rem .6rem;color:var(--text2);
  transition:all .2s;
}
.chip:hover{border-color:var(--accent);color:var(--text)}

/* ═══════════════════════ SKILLS RADAR (POLYGON CHART) ═══════════════════════ */
#skills{background:var(--bg)}
.skills-layout{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center}
.radar-wrap{
  display:flex;justify-content:center;
  position:relative;
}
#radar-canvas{width:100%;max-width:380px;height:auto}
.skills-list{display:flex;flex-direction:column;gap:1rem}
.skill-bar-item{}
.skill-bar-header{
  display:flex;justify-content:space-between;align-items:center;
  margin-bottom:.4rem;
}
.skill-bar-name{font-family:var(--mono);font-size:.72rem;color:var(--text)}
.skill-bar-pct{font-family:var(--mono);font-size:.65rem;color:var(--accent)}
.skill-bar-track{
  height:4px;background:var(--border);border-radius:4px;overflow:hidden;
}
.skill-bar-fill{
  height:100%;border-radius:4px;
  background:var(--grad);
  transform:scaleX(0);transform-origin:left;
  transition:transform 1.2s cubic-bezier(.23,1,.32,1);
}
.skill-bar-fill.animate{transform:scaleX(1)}

/* ═══════════════════════ CONTRIBUTION GRAPH ═══════════════════════ */
#activity{background:var(--bg2)}
.contrib-wrap{margin-top:1.5rem}
.contrib-header{
  display:flex;align-items:center;justify-content:space-between;
  margin-bottom:1rem;flex-wrap:wrap;gap:.75rem;
}
.contrib-total{
  font-family:var(--mono);font-size:.75rem;color:var(--accent3);
}
.contrib-legend{
  display:flex;align-items:center;gap:.4rem;
  font-family:var(--mono);font-size:.55rem;color:var(--text3);
}
.legend-dot{width:10px;height:10px;border-radius:2px}
.contrib-grid-scroll{overflow-x:auto;padding-bottom:.5rem}
.contrib-months{
  display:flex;margin-left:24px;margin-bottom:4px;gap:3px;
  font-family:var(--mono);font-size:.5rem;color:var(--text3);
}
.contrib-month-label{flex:0 0 auto}
.contrib-outer{display:flex;gap:3px;min-width:max-content}
.contrib-day-labels{
  display:flex;flex-direction:column;gap:3px;margin-right:3px;
  font-family:var(--mono);font-size:.5rem;color:var(--text3);justify-content:space-between;
}
.contrib-week{display:flex;flex-direction:column;gap:3px}
.contrib-cell{
  width:11px;height:11px;border-radius:2px;
  background:var(--border);flex-shrink:0;
  transition:transform .1s;cursor:default;
}
.contrib-cell:hover{transform:scale(1.4)}
.contrib-cell[data-level="1"]{background:rgba(67,233,123,.25)}
.contrib-cell[data-level="2"]{background:rgba(67,233,123,.5)}
.contrib-cell[data-level="3"]{background:rgba(67,233,123,.75)}
.contrib-cell[data-level="4"]{background:rgba(67,233,123,1)}

/* ═══════════════════════ PROJECTS ═══════════════════════ */
#projects{background:var(--bg)}
.repos-top{
  display:flex;align-items:flex-end;justify-content:space-between;
  margin-bottom:2rem;flex-wrap:wrap;gap:1rem;
}
.gh-link-pill{
  display:inline-flex;align-items:center;gap:.5rem;
  font-family:var(--mono);font-size:.68rem;color:var(--text3);
  border:1px solid var(--border);border-radius:7px;
  padding:.4rem .85rem;transition:all .2s;
}
.gh-link-pill:hover{border-color:var(--accent);color:var(--accent)}
.gh-stats-row{
  display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;
  margin-bottom:2.5rem;
}
.ghs-card{
  background:var(--card);border:1px solid var(--border);
  border-radius:var(--radius);padding:1.1rem;text-align:center;
  transition:all .2s;position:relative;overflow:hidden;
}
.ghs-card::before{
  content:'';position:absolute;inset:0;
  background:var(--grad);opacity:0;transition:opacity .2s;
}
.ghs-card:hover{border-color:var(--border2)}
.ghs-card:hover::before{opacity:.04}
.ghs-val{font-family:var(--mono);font-size:1.5rem;font-weight:600;color:var(--accent)}
.ghs-lbl{font-size:.6rem;text-transform:uppercase;letter-spacing:.1em;color:var(--text3);margin-top:4px}

#repos-grid{
  display:grid;grid-template-columns:repeat(auto-fill,minmax(310px,1fr));
  gap:1rem;
}
.repo-card{
  background:var(--card);border:1px solid var(--border);
  border-radius:var(--radius);
  transition:all .25s;position:relative;overflow:hidden;
}
.repo-card::before{
  content:'';position:absolute;inset:0;
  background:var(--grad);opacity:0;transition:opacity .25s;pointer-events:none;
}
.repo-card:hover{border-color:var(--border2);transform:translateY(-3px);
  box-shadow:0 12px 40px rgba(108,99,255,.12)}
.repo-card:hover::before{opacity:.04}
.repo-card-link{display:block;padding:1.2rem;height:100%}
.repo-top{display:flex;align-items:flex-start;justify-content:space-between;gap:.5rem;margin-bottom:.5rem}
.repo-name{font-family:var(--mono);font-size:.8rem;font-weight:600;color:var(--text)}
.repo-star-badge{
  font-family:var(--mono);font-size:.6rem;
  background:rgba(255,209,102,.1);border:1px solid rgba(255,209,102,.25);
  color:var(--amber);border-radius:5px;padding:.15rem .45rem;white-space:nowrap;flex-shrink:0;
}
.repo-desc{font-size:.75rem;color:var(--text2);line-height:1.7;margin-bottom:.75rem}
.repo-topics{display:flex;flex-wrap:wrap;gap:.3rem;margin-bottom:.75rem}
.repo-topic{
  font-family:var(--mono);font-size:.55rem;
  background:var(--accent-dim);border:1px solid rgba(108,99,255,.2);
  color:var(--accent);border-radius:5px;padding:.15rem .45rem;
}
.repo-footer{
  display:flex;justify-content:space-between;align-items:center;
  margin-top:auto;
}
.repo-meta{display:flex;align-items:center;gap:.65rem;flex-wrap:wrap}
.repo-meta-item{
  display:flex;align-items:center;gap:.3rem;
  font-family:var(--mono);font-size:.6rem;color:var(--text3);
}
.lang-dot{width:8px;height:8px;border-radius:50%}
.repo-link-btn{
  font-family:var(--mono);font-size:.62rem;color:var(--accent);
  opacity:0;transition:opacity .2s;white-space:nowrap;
}
.repo-card:hover .repo-link-btn{opacity:1}
.load-more-wrap{text-align:center;margin-top:2rem}
.loading-state{
  text-align:center;padding:4rem 2rem;
  font-family:var(--mono);font-size:.75rem;color:var(--text3);
  grid-column:1/-1;
}

/* ═══════════════════════ EDUCATION ═══════════════════════ */
#education{background:var(--bg2)}
.edu-timeline{position:relative;padding-left:1.5rem}
.edu-timeline::before{
  content:'';position:absolute;left:0;top:8px;bottom:8px;
  width:1px;background:linear-gradient(to bottom,var(--accent),transparent);
}
.edu-item{position:relative;padding-bottom:2.5rem;padding-left:1.5rem}
.edu-item:last-child{padding-bottom:0}
.edu-dot{
  position:absolute;left:-1.875rem;top:6px;
  width:10px;height:10px;border-radius:50%;
  background:var(--accent);
  box-shadow:0 0 12px var(--accent-glow);
}
.edu-year{font-family:var(--mono);font-size:.62rem;color:var(--accent);margin-bottom:.3rem;letter-spacing:.06em}
.edu-degree{font-family:var(--display);font-weight:700;font-size:1rem;margin-bottom:.2rem}
.edu-school{font-size:.82rem;color:var(--text2);margin-bottom:.2rem}
.edu-grade{font-family:var(--mono);font-size:.65rem;color:var(--text3)}

/* ═══════════════════════ CONTACT ═══════════════════════ */
#contact{background:var(--bg)}
.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:3.5rem;align-items:start}
.contact-left h3{
  font-family:var(--display);font-weight:800;
  font-size:1.5rem;margin-bottom:1rem;line-height:1.2;
}
.contact-left p{font-size:.85rem;color:var(--text2);line-height:1.85;margin-bottom:1.5rem}
.contact-methods{display:flex;flex-direction:column;gap:.6rem;margin-bottom:1.5rem}
.cm{
  display:flex;align-items:center;gap:.65rem;
  font-size:.8rem;color:var(--text2);
  transition:color .2s;
}
.cm svg{width:16px;height:16px;flex-shrink:0;color:var(--accent)}
.cm:hover{color:var(--text)}

.form{display:flex;flex-direction:column;gap:1rem}
.f-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
.fg{display:flex;flex-direction:column;gap:.4rem}
.fg label{font-family:var(--mono);font-size:.62rem;text-transform:uppercase;letter-spacing:.1em;color:var(--text3)}
.fg input,.fg textarea,.fg select{
  background:var(--card);border:1px solid var(--border);
  border-radius:8px;padding:.7rem 1rem;
  font-size:.82rem;color:var(--text);outline:none;
  transition:border-color .2s;
  resize:none;
}
.fg input:focus,.fg textarea:focus{border-color:var(--accent)}
.fg textarea{min-height:120px}
.notice-box{
  font-family:var(--mono);font-size:.65rem;color:var(--text3);
  background:var(--card);border:1px solid var(--border);border-left:3px solid var(--amber);
  border-radius:6px;padding:.75rem 1rem;line-height:1.7;
}
.notice-box a{color:var(--amber);text-decoration:underline}
.notice-box code{color:var(--accent);font-size:.6rem}
.form-actions{display:flex;align-items:center;gap:1rem;flex-wrap:wrap}
#form-status{font-family:var(--mono);font-size:.7rem}
#form-status.ok{color:var(--accent3)}
#form-status.err{color:var(--accent2)}

/* ═══════════════════════ FOOTER ═══════════════════════ */
footer{
  margin-left:var(--sidebar);
  text-align:center;padding:2rem;
  border-top:1px solid var(--border);
  font-size:.72rem;color:var(--text3);
  font-family:var(--mono);
}
footer a{color:var(--accent);transition:color .2s}
footer a:hover{color:var(--text)}

/* ═══════════════════════ FADE ANIMATIONS ═══════════════════════ */
.fade-up{opacity:0;transform:translateY(20px);transition:opacity .6s,transform .6s}
.fade-up.in{opacity:1;transform:translateY(0)}

/* ═══════════════════════ ADMIN MODAL ═══════════════════════ */
.modal-bg{
  display:none;position:fixed;inset:0;
  background:rgba(8,8,15,.85);backdrop-filter:blur(8px);
  z-index:9000;align-items:center;justify-content:center;
}
.modal-bg.open{display:flex}
.modal{
  background:var(--bg2);border:1px solid var(--border2);
  border-radius:16px;padding:2rem;width:min(600px,95vw);
  max-height:90vh;overflow-y:auto;
  box-shadow:0 30px 80px rgba(0,0,0,.5);
  position:relative;
}
.modal-head{
  display:flex;align-items:center;justify-content:space-between;
  margin-bottom:1.5rem;
}
.modal-head h3{font-family:var(--display);font-weight:800;font-size:1.3rem}
.modal-close{
  background:none;border:1px solid var(--border);border-radius:7px;
  color:var(--text3);font-size:1rem;width:30px;height:30px;
  display:flex;align-items:center;justify-content:center;
  transition:all .2s;
}
.modal-close:hover{border-color:var(--accent2);color:var(--accent2)}
.modal-section{margin-bottom:1.25rem}
.modal-section label{
  display:block;font-family:var(--mono);font-size:.6rem;
  text-transform:uppercase;letter-spacing:.1em;color:var(--text3);
  margin-bottom:.4rem;
}
.modal-section input,.modal-section textarea{
  width:100%;background:var(--bg3);border:1px solid var(--border);
  border-radius:8px;padding:.65rem 1rem;font-size:.82rem;
  color:var(--text);outline:none;transition:border-color .2s;resize:vertical;
}
.modal-section input:focus,.modal-section textarea:focus{border-color:var(--accent)}
.modal-actions{display:flex;justify-content:flex-end;gap:.75rem;margin-top:1.25rem}

/* Login form inside modal */
.login-form{display:flex;flex-direction:column;gap:1rem;max-width:320px;margin:0 auto}
.login-form h3{font-family:var(--display);font-weight:800;font-size:1.2rem;text-align:center;margin-bottom:.5rem}
.login-err{font-family:var(--mono);font-size:.65rem;color:var(--accent2);text-align:center;min-height:1rem}

/* ═══════════════════════ MOBILE HAMBURGER ═══════════════════════ */
#hamburger{
  display:none;position:fixed;top:1rem;left:1rem;z-index:200;
  background:var(--card);border:1px solid var(--border);
  border-radius:8px;padding:.5rem;width:38px;height:38px;
  flex-direction:column;justify-content:center;gap:5px;
  cursor:pointer;
}
#hamburger span{display:block;height:2px;background:var(--text);border-radius:2px;transition:all .3s}
#hamburger.open span:nth-child(1){transform:rotate(45deg) translate(5px,5px)}
#hamburger.open span:nth-child(2){opacity:0}
#hamburger.open span:nth-child(3){transform:rotate(-45deg) translate(5px,-5px)}
.sidebar-overlay{
  display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:99;
}
.sidebar-overlay.open{display:block}

/* ═══════════════════════ RESPONSIVE ═══════════════════════ */
@media(max-width:900px){
  :root{--sidebar:0px}
  #sidebar{transform:translateX(-100%);transition:transform .3s;width:270px}
  #sidebar.open{transform:translateX(0)}
  #main{margin-left:0}
  footer{margin-left:0}
  #hamburger{display:flex}
  .about-grid,.skills-layout,.contact-grid{grid-template-columns:1fr}
  .gh-stats-row{grid-template-columns:1fr 1fr}
  #hero{padding:5rem 2rem 3rem}
  .section{padding:3.5rem 2rem}
  #repos-grid{grid-template-columns:1fr}
  .f-row{grid-template-columns:1fr}
}
</style>
</head>
