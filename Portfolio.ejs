/* ═══════════════════════ RESUME DOWNLOAD ═══════════════════════ */
async function downloadResume(){
  const url=CFG.resumeURL;
  if(!url){
    alert('No resume URL configured. Please log into the Admin Panel and add your GitHub raw URL for resume.tex.');
    return;
  }
  try{
    const res=await fetch(url);
    if(!res.ok)throw new Error('Could not fetch resume');
    const blob=await res.blob();
    const a=document.createElement('a');
    a.href=URL.createObjectURL(blob);
    a.download='resume.tex';
    document.body.appendChild(a);a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(a.href);
  }catch(e){
    alert('Could not download resume. Please check the URL in the Admin Panel.\n\n'+e.message);
  }
}

