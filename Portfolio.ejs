/* ═══════════════════════ GITHUB FETCH ═══════════════════════ */
let allRepos=[],shown=6;

async function fetchGH(){
  try{
    const[uR,rR]=await Promise.all([
      fetch(`https://api.github.com/users/${CFG.github}`),
      fetch(`https://api.github.com/users/${CFG.github}/repos?per_page=100&sort=updated`)
    ]);
    const u=await uR.json(),r=await rR.json();
    if(u.message||!Array.isArray(r))throw new Error(u.message||'API error');

    // Avatar
    if(u.avatar_url){
      const img=document.getElementById('av-img');
      const ph=document.getElementById('av-placeholder');
      img.src=u.avatar_url;img.style.display='block';
      if(ph)ph.style.display='none';
    }

    // Bio location from github if not overridden
    const d=loadData();
    if(!d.location&&u.location){
      document.getElementById('hero-location').textContent=u.location;
      document.getElementById('code-location').textContent=u.location;
    }

    const stars=r.reduce((s,x)=>s+x.stargazers_count,0);
    const forks=r.reduce((s,x)=>s+x.forks_count,0);
    const langs=[...new Set(r.map(x=>x.language).filter(Boolean))];

    // Sidebar stats
    document.getElementById('sm-repos').textContent=u.public_repos;
    document.getElementById('sm-stars').textContent=stars;
    document.getElementById('sm-followers').textContent=u.followers;
    document.getElementById('sm-langs').textContent=langs.length;

    // Projects section stats
    document.getElementById('ghs-repos').textContent=u.public_repos;
    document.getElementById('ghs-stars').textContent=stars;
    document.getElementById('ghs-forks').textContent=forks;
    document.getElementById('ghs-followers').textContent=u.followers;

    // Code block
    document.getElementById('code-repos').textContent=u.public_repos;
    document.getElementById('code-stars').textContent=stars;
    document.getElementById('code-skills').textContent=
      langs.slice(0,4).map(l=>`'${l}'`).join(', ');

    // About chips
    if(langs.length){
      document.getElementById('about-chips').innerHTML=
        [...langs.slice(0,8),'Git & GitHub','REST APIs','Open Source']
        .map(l=>`<span class="chip">${l}</span>`).join('');
    }

    // Hero tags
    document.getElementById('hero-tags').innerHTML=
      [...langs.slice(0,5),'Open Source']
      .map(l=>`<span class="htag">${l}</span>`).join('');

    // Repos
    allRepos=r.filter(x=>!x.fork)
      .sort((a,b)=>b.stargazers_count-a.stargazers_count||
        new Date(b.updated_at)-new Date(a.updated_at));
    renderRepos();

  }catch(err){
    document.getElementById('repos-grid').innerHTML=
      `<div class="loading-state" style="color:#ff6584">
        ⚠ Could not load repositories (${err.message})<br>
        <a href="https://github.com/${CFG.github}" target="_blank" style="color:var(--accent)">Browse on GitHub →</a>
      </div>`;
  }
}

function renderRepos(){
  const grid=document.getElementById('repos-grid');
  const slice=allRepos.slice(0,shown);
  if(!slice.length){grid.innerHTML='<div class="loading-state">No repositories found.</div>';return;}
  grid.innerHTML=slice.map(r=>{
    const lang=r.language||'';
    const col=LANG_COLORS[lang]||LANG_COLORS.default;
    const desc=r.description||'No description provided.';
    const topics=(r.topics||[]).slice(0,3).map(t=>`<span class="repo-topic">${t}</span>`).join('');
    const upd=new Date(r.updated_at).toLocaleDateString('en-IN',{month:'short',year:'numeric'});
    return`<div class="repo-card fade-up">
      <a href="${r.html_url}" target="_blank" class="repo-card-link">
        <div class="repo-top">
          <div class="repo-name">
