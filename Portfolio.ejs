/* ═══════════════════════ CONTRIBUTION GRAPH ═══════════════════════ */
async function fetchContributions(){
  const container=document.getElementById('contrib-graph');
  const ldots2=document.getElementById('ldots2');

  // GitHub doesn't expose contribution data directly in REST API without auth.
  // We'll use the github-contributions-api proxy or build a synthetic graph
  // from commit events + fall back to a simulated graph.
  try {
    // Try unofficial GitHub contributions API
    const res=await fetch(`https://github-contributions-api.jogruber.de/v4/${CFG.github}?y=last`);
    if(!res.ok) throw new Error('API unavailable');
    const data=await res.json();
    renderContribGraph(data.contributions,data.total['lastYear']||0);
  } catch(e){
    // Fallback: fetch user events and build partial graph
    try {
      const evRes=await fetch(`https://api.github.com/users/${CFG.github}/events?per_page=100`);
      const events=await evRes.json();
      buildGraphFromEvents(events);
    } catch(e2){
      container.innerHTML='<div class="loading-state" style="color:var(--text3)">Could not load contribution data. GitHub API rate limit may apply.</div>';
    }
  }
}

function buildGraphFromEvents(events){
  // Build a 52-week grid from events
  const counts={};
  if(Array.isArray(events)){
    events.forEach(ev=>{
      if(ev.type==='PushEvent'||ev.type==='CreateEvent'||ev.type==='PullRequestEvent'){
        const day=ev.created_at.slice(0,10);
        counts[day]=(counts[day]||0)+(ev.type==='PushEvent'?(ev.payload?.commits?.length||1):1);
      }
    });
  }
  // Create 52 weeks of data
  const weeks=[];
  const now=new Date();
  now.setHours(0,0,0,0);
  // Go back 52 weeks from today (align to Sunday)
  const start=new Date(now);
  start.setDate(start.getDate()-(start.getDay()+(52*7)));
  let total=0;
  for(let w=0;w<53;w++){
    const week=[];
    for(let d=0;d<7;d++){
      const date=new Date(start);
      date.setDate(start.getDate()+(w*7+d));
      if(date>now){week.push(null);continue;}
      const key=date.toISOString().slice(0,10);
      const count=counts[key]||0;
      total+=count;
      week.push({date:key,count});
    }
    weeks.push(week);
  }
  renderContribGraph(weeks.flat().filter(Boolean),total);
}

function renderContribGraph(contributions,total){
  document.getElementById('contrib-total').textContent=`${total.toLocaleString()} contributions in the last year`;

  // Build week columns
  const now=new Date();now.setHours(0,0,0,0);
  const start=new Date(now);
  start.setDate(start.getDate()-364-start.getDay());

  // Map contributions by date
  const byDate={};
  if(Array.isArray(contributions)){
    contributions.forEach(c=>{
      // Handle both {date,count} and nested formats
      const dateKey=c.date||(c instanceof Object?Object.keys(c)[0]:null);
      if(dateKey) byDate[dateKey]=c.count||c[dateKey]||0;
    });
  }

  const weeks=[];
  const monthLabels=[];
  let lastMonth=-1;

  for(let w=0;w<53;w++){
    const week=[];
    for(let d=0;d<7;d++){
      const date=new Date(start);
      date.setDate(start.getDate()+(w*7+d));
      if(date>now){week.push(null);continue;}
      const key=date.toISOString().slice(0,10);
      const count=byDate[key]||0;
      const month=date.getMonth();
      if(d===0&&month!==lastMonth){
        monthLabels.push({week:w,label:date.toLocaleString('en',{month:'short'})});
        lastMonth=month;
      }
      week.push({date:key,count,label:date.toLocaleDateString('en',{month:'short',day:'numeric',year:'numeric'})});
    }
    weeks.push(week);
  }

  function level(n){if(n===0)return 0;if(n<=2)return 1;if(n<=5)return 2;if(n<=9)return 3;return 4;}

  const DAY_LABELS=['','Mon','','Wed','','Fri',''];

  let html=`<div style="display:flex;gap:3px;align-items:flex-start">
    <div class="contrib-day-labels">
      ${DAY_LABELS.map(l=>`<div style="height:11px;line-height:11px">${l}</div>`).join('')}
    </div>
    <div style="display:flex;flex-direction:column;overflow:hidden;width:100%">
      <div class="contrib-months">`;

  // Month labels row
  let cursor=0;
  monthLabels.forEach((ml,i)=>{
    const nextWeek=monthLabels[i+1]?.week||53;
    const span=nextWeek-ml.week;
    html+=`<div style="flex:0 0 ${span*(11+3)}px;overflow:hidden;white-space:nowrap">${ml.label}</div>`;
  });

  html+=`</div><div style="display:flex;gap:3px">`;
  weeks.forEach(week=>{
    html+=`<div class="contrib-week">`;
    week.forEach(day=>{
      if(!day){html+=`<div style="width:11px;height:11px;border-radius:2px;background:transparent"></div>`;return;}
      html+=`<div class="contrib-cell" data-level="${level(day.count)}" title="${day.label}: ${day.count} contribution${day.count!==1?'s':''}"></div>`;
    });
    html+=`</div>`;
  });
  html+=`</div></div></div>`;

  document.getElementById('contrib-graph').innerHTML=html;
}

/* ═══════════════════════ POLYGON / RADAR CHART ═══════════════════════ */
function drawRadar(){
  const canvas=document.getElementById('radar-canvas');
  if(!canvas)return;
  const ctx=canvas.getContext('2d');
  const W=canvas.width,H=canvas.height;
  const cx=W/2,cy=H/2,R=Math.min(W,H)/2-40;
  const N=SKILLS_DATA.length;
  const angleStep=(2*Math.PI)/N;
  const startAngle=-Math.PI/2;

  ctx.clearRect(0,0,W,H);

  // Draw spider web rings
  const rings=5;
  for(let r=1;r<=rings;r++){
    const frac=r/rings;
    ctx.beginPath();
    for(let i=0;i<=N;i++){
      const a=startAngle+i*angleStep;
      const x=cx+Math.cos(a)*R*frac;
      const y=cy+Math.sin(a)*R*frac;
      i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);
    }
    ctx.closePath();
    ctx.strokeStyle=`rgba(108,99,255,${0.08+r*0.03})`;
    ctx.lineWidth=1;
    ctx.stroke();
    if(r===rings){ctx.fillStyle='rgba(108,99,255,0.03)';ctx.fill();}
  }

  // Axis lines
  for(let i=0;i<N;i++){
    const a=startAngle+i*angleStep;
    ctx.beginPath();
    ctx.moveTo(cx,cy);
    ctx.lineTo(cx+Math.cos(a)*R,cy+Math.sin(a)*R);
    ctx.strokeStyle='rgba(108,99,255,0.15)';
    ctx.lineWidth=1;
    ctx.stroke();
  }

  // Data polygon
  ctx.beginPath();
  SKILLS_DATA.forEach((s,i)=>{
    const a=startAngle+i*angleStep;
    const frac=s.value/100;
    const x=cx+Math.cos(a)*R*frac;
    const y=cy+Math.sin(a)*R*frac;
    i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);
  });
  ctx.closePath();
  const grad=ctx.createRadialGradient(cx,cy,0,cx,cy,R);
  grad.addColorStop(0,'rgba(108,99,255,0.35)');
  grad.addColorStop(1,'rgba(255,101,132,0.15)');
  ctx.fillStyle=grad;
  ctx.fill();
  ctx.strokeStyle='rgba(108,99,255,0.8)';
  ctx.lineWidth=2;
  ctx.stroke();

  // Data points
  SKILLS_DATA.forEach((s,i)=>{
    const a=startAngle+i*angleStep;
    const frac=s.value/100;
    const x=cx+Math.cos(a)*R*frac;
    const y=cy+Math.sin(a)*R*frac;
    ctx.beginPath();
    ctx.arc(x,y,4,0,2*Math.PI);
    ctx.fillStyle=s.color;
    ctx.fill();
    ctx.strokeStyle='var(--bg)';
    ctx.lineWidth=2;
    ctx.stroke();
  });

  // Labels
  ctx.textAlign='center';ctx.textBaseline='middle';
  SKILLS_DATA.forEach((s,i)=>{
    const a=startAngle+i*angleStep;
    const labelR=R+24;
    const x=cx+Math.cos(a)*labelR;
    const y=cy+Math.sin(a)*labelR;
    ctx.font='bold 11px "Fira Code", monospace';
    ctx.fillStyle='rgba(240,238,255,0.9)';
    ctx.fillText(s.name,x,y);
  });
}

function renderSkillBars(){
  const list=document.getElementById('skills-list');
  list.innerHTML=SKILLS_DATA.map(s=>`
    <div class="skill-bar-item">
      <div class="skill-bar-header">
        <span class="skill-bar-name">${s.name}</span>
        <span class="skill-bar-pct">${s.value}%</span>
      </div>
      <div class="skill-bar-track">
        <div class="skill-bar-fill" style="width:${s.value}%"></div>
      </div>
    </div>
  `).join('');

  // Animate bars when visible
  const io=new IntersectionObserver(entries=>{
    if(entries[0].isIntersecting){
      document.querySelectorAll('.skill-bar-fill').forEach((el,i)=>{
        setTimeout(()=>el.classList.add('animate'),i*80);
      });
      io.disconnect();
    }
  },{threshold:.2});
  const skillsSection=document.getElementById('skills');
  if(skillsSection)io.observe(skillsSection);
}

/* ═══════════════════════ EMAIL ═══════════════════════ */
async function sendEmail(e){
  e.preventDefault();
  const btn=document.getElementById('send-btn');
  const st=document.getElementById('form-status');
  btn.textContent='Sending…';btn.disabled=true;
  st.className='';st.textContent='';

  if(CFG.ejPublicKey==='YOUR_PUBLIC_KEY'){
    st.textContent='⚙ EmailJS not configured yet.';
    st.className='err';
    btn.innerHTML='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg> Send Message';
    btn.disabled=false;return;
  }
  try{
    await emailjs.sendForm(CFG.ejServiceId,CFG.ejTemplateId,e.target);
    st.textContent='✓ Message sent! I\'ll reply soon.';st.className='ok';
    e.target.reset();
  }catch(err){
    st.textContent=`✗ ${err.text||err.message||'Unknown error'}`;st.className='err';
  }
  btn.innerHTML='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg> Send Message';
  btn.disabled=false;
}

/* ═══════════════════════ SCROLL & NAV ═══════════════════════ */
function observeFade(){
  const io=new IntersectionObserver(entries=>{
    entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);}});
  },{threshold:.06});
  document.querySelectorAll('.fade-up:not(.in)').forEach(el=>io.observe(el));
}
function setActiveNav(){
  const ids=['hero','about','skills','activity','projects','education','contact'];
  const scrollY=window.scrollY+100;
  let active='hero';
  for(const id of ids){
    const el=document.getElementById(id);
    if(el&&el.offsetTop<=scrollY)active=id;
  }
  document.querySelectorAll('nav ul a').forEach(a=>{
    a.classList.toggle('active',a.getAttribute('href')==='#'+active);
  });
}
window.addEventListener('scroll',setActiveNav,{passive:true});

